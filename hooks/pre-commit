#!/usr/bin/env bash
#
# pre-commit hook de presuntamente.org
#
# Archiva en web.archive.org URLs nuevas sin url_archivo en:
#   - content/documentos/*.yaml (N4 con url_canonica)
#   - content/cobertura-mediatica/*.yaml (noticias con url)
#
# Activación (una sola vez por máquina):
#   git config core.hooksPath hooks
#
# Comportamiento:
#   - Solo procesa ficheros en staging; tope 5 URLs por commit (8s entre
#     llamadas ≈ ~1 min). Si hay más pendientes, el script avisa y sugiere
#     pnpm archive:catchup (manual, sin tope).
#   - Si archive.org falla: avisa pero PERMITE el commit.
#   - Saltar puntualmente: git commit --no-verify
#
# NUNCA bloquea el commit por errores del archivado.

set -e

if ! command -v node >/dev/null 2>&1; then
  exit 0
fi

if [ ! -f "scripts/archivar-n4.mjs" ]; then
  exit 0
fi

STAGED_DOCS=$(git diff --cached --name-only --diff-filter=AM -- 'content/documentos/*.yaml' | head -1)
STAGED_COB=$(git diff --cached --name-only --diff-filter=AM -- 'content/cobertura-mediatica/*.yaml' | head -1)

if [ -z "$STAGED_DOCS" ] && [ -z "$STAGED_COB" ]; then
  exit 0
fi

node scripts/archivar-n4.mjs --staged-only || true

exit 0
