{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presuntamente.org/schemas/delito.schema.json",
  "title": "Delito",
  "description": "Catálogo de referencia de tipos penales. Ver docs/diseno/01-modelo-de-datos.md §2.9.",
  "type": "object",
  "required": ["id", "nombre_tipico", "articulos_cp", "familia"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "nombre_tipico": { "type": "string", "minLength": 1 },
    "articulos_cp": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "familia": {
      "type": "string",
      "enum": [
        "contra_administracion_publica",
        "contra_patrimonio_y_orden_socioeconomico",
        "falsedad_documental",
        "delitos_electorales",
        "blanqueo_capitales",
        "pertenencia_organizacion_criminal",
        "cohecho_y_trafico_influencias",
        "otros"
      ]
    },
    "descripcion_breve": { "type": "string" },
    "enlace_boe": { "type": "string", "format": "uri" }
  }
}
