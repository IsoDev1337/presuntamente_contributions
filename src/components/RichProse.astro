---
// RichProse — renderiza texto plano enriqueciendo:
//   - Cifras monetarias (chips con forma corta canónica).
//   - Acrónimos institucionales y nombres de organización (link a /organizaciones/<slug>).
//   - Personas con rol formal en el inventario (link a /personas/<slug>).
//   - Escape hatch [[org:slug|label]] / [[persona:slug|label]] / [[€:53,5 M€]].
//
// Carga las collections una vez por invocación; Astro deduplica entre llamadas.
//
// Uso:
//   <RichProse text={hecho.enunciado} />                                  (default: <p>)
//   <RichProse text={hito.descripcion} as="div" />
//   <RichProse text={persona.biografia_corta} excludePersonaIds={[persona.id]} />
//   <RichProse text={org.descripcion_corta} excludeOrgIds={[org.id]} />

import { getCollection } from 'astro:content';
import {
  richProse,
  type OrgLite,
  type PersonaLite,
  type DelitoLite,
  type GlosarioLite,
} from '@/lib/richProse';
import { entidadesEnCasosVisibles } from '@/lib/visibilidad';

interface Props {
  text: string;
  /** Etiqueta envolvente. Default 'p'. */
  as?: 'p' | 'div' | 'span';
  lang?: 'es' | 'ca';
  class?: string;
  /** IDs de organizaciones que NO deben auto-enlazarse en este contexto
   *  (típicamente la propia ficha de organización). */
  excludeOrgIds?: string[];
  /** IDs de personas que NO deben auto-enlazarse en este contexto
   *  (típicamente la propia ficha de persona). */
  excludePersonaIds?: string[];
}

const {
  text,
  as: Tag = 'p',
  lang = 'es',
  class: className,
  excludeOrgIds,
  excludePersonaIds,
} = Astro.props as Props;

const [orgsCol, personasCol, delitosCol, glosarioCol, casosCol, rolesCol, hechosCol, hitosCol, vinculosCol, documentosCol] = await Promise.all([
  getCollection('organizaciones'),
  getCollection('personas'),
  getCollection('delitos'),
  getCollection('glosario'),
  getCollection('casos'),
  getCollection('roles'),
  getCollection('hechos'),
  getCollection('hitos'),
  getCollection('vinculos'),
  getCollection('documentos'),
]);

// Sólo se auto-enlazan entidades cuya ficha se genera en este entorno (en prod,
// las ligadas a un caso visible). Una organización o persona mencionada en la
// prosa pero sin página pública se renderiza como texto plano: no debe quedar un
// enlace a una página inexistente ni asomar una entidad de un caso en borrador.
const ent = entidadesEnCasosVisibles({
  casos: casosCol,
  roles: rolesCol,
  hechos: hechosCol as unknown as { data: { caso_id: string; personas_implicadas?: string[]; organizaciones_implicadas?: string[] } }[],
  hitos: hitosCol,
  vinculos: vinculosCol,
  documentos: documentosCol,
});

// En dev se generan todas las fichas, así que se auto-enlazan todas; en prod
// sólo las que tienen página (ligadas a un caso visible).
const gateLinks = !import.meta.env.DEV;

const orgs: OrgLite[] = orgsCol
  .filter((o) => !gateLinks || ent.organizaciones.has(o.data.id))
  .map((o) => ({
    id: o.data.id,
    nombre: o.data.nombre,
    nombres_alternativos: (o.data as { nombres_alternativos?: string[] }).nombres_alternativos,
    siglas: (o.data as { siglas?: string }).siglas,
  }));

const personas: PersonaLite[] = personasCol
  .filter((p) => !gateLinks || ent.personas.has(p.data.id))
  .map((p) => ({
    id: p.data.id,
    nombre_completo: p.data.nombre_completo,
    nombres_alternativos: (p.data as { nombres_alternativos?: string[] }).nombres_alternativos,
  }));

const delitos: DelitoLite[] = delitosCol.map((d) => ({
  id: d.data.id,
  nombre_tipico: d.data.nombre_tipico,
}));

const glosario: GlosarioLite[] = glosarioCol.map((g) => ({
  id: g.data.id,
  label: g.data.label,
  nombres_alternativos: g.data.nombres_alternativos,
  descripcion_breve: g.data.descripcion_breve,
}));

const html = richProse(text, {
  orgs,
  personas,
  delitos,
  glosario,
  excludeOrgIds,
  excludePersonaIds,
  // Activado: /delitos/[slug].astro existe desde 2026-05-22.
  enableDelitos: true,
  lang,
});
---
<Tag class={className} set:html={html} />
