---
// EpistemicBadge — badge de estado epistémico de un Hecho (familia F2).
// 6 valores en el modelo (doc 01 §2.6), 4 colores con sub-tipo por borde:
//   - acreditado     → verde sobrio, borde sólido
//   - investigado    → ámbar, borde sólido
//   - atribuido      → ámbar, borde DASHED (sub-tipo de investigado)
//   - exculpatorio   → gris azulado, borde sólido
//   - desmentido     → gris neutro, borde sólido
//   - no_concluyente → gris neutro, borde DASHED (sub-tipo de desmentido)
// El estado se transmite por TRES canales: color + label + dot. Nunca solo
// color (DESIGN.md §7 "Do"). El borde dashed distingue sub-tipos sin
// introducir colores nuevos. Nunca rojo (DESIGN.md §2).

interface Props {
  tipo: 'acreditado' | 'investigado' | 'atribuido' | 'exculpatorio' | 'desmentido' | 'no_concluyente';
}
const { tipo } = Astro.props;

const VARIANT = {
  acreditado:     { cls: 'acreditado',     label: 'Acreditado' },
  investigado:    { cls: 'investigado',    label: 'Investigado' },
  atribuido:      { cls: 'atribuido',      label: 'Atribuido' },
  exculpatorio:   { cls: 'exculpatorio',   label: 'Exculpatorio' },
  desmentido:     { cls: 'desmentido',     label: 'Desmentido' },
  no_concluyente: { cls: 'no-concluyente', label: 'No concluyente' },
} as const;

const { cls, label } = VARIANT[tipo];
---
<span class:list={['badge', `badge--${cls}`]}>
  <span class="dot" aria-hidden="true"></span>
  {label}
</span>
