---
/**
 * PgTraduccionCatalan — página de aviso mientras la versión catalana
 * del sitio está en preparación.
 *
 * El selector de idioma del header apunta siempre a `/cat`. Para no
 * mostrar un 404 crudo al usuario catalanohablante, esta página
 * informa de que la traducción está en camino y devuelve a la
 * navegación castellana. Se sirve en `lang="es"` a propósito: el
 * contenido del sitio aún no existe en catalán.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Traducció al català en preparació"
  lang="es"
  description="La versión catalana de presuntamente.org está en preparación. Mientras tanto, el contenido está disponible en castellano."
  breadcrumb={[
    { label: 'Inicio', href: '/' },
    { label: 'Versión catalana' },
  ]}
>
  <div class="pg-cat">
    <div class="pg-cat__inner">
      <p class="pg-cat__eyebrow" lang="ca">Versió catalana</p>
      <h1 class="pg-cat__title" lang="ca">Traducció al català en preparació</h1>

      <div class="pg-cat__body">
        <p lang="ca">
          presuntamente.org és un inventari públic dels casos de corrupció
          més rellevants a Espanya. La versió en català està prevista i
          s'activarà progressivament a mesura que la traducció avança.
        </p>
        <p>
          Mientras tanto, todo el contenido editorial está disponible en
          castellano. Las fuentes documentales originales (autos,
          sentencias, BOE, informes) se conservan en su idioma de
          publicación.
        </p>
      </div>

      <div class="pg-cat__actions">
        <a href="/" class="btn-primary">Continuar en castellano</a>
        <a href="/sobre" class="btn-ghost">Sobre el proyecto</a>
      </div>

      <p class="pg-cat__meta">
        Si quieres colaborar con la traducción al catalán, escribe a
        <a href="mailto:aportar@presuntamente.org">aportar@presuntamente.org</a>.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .pg-cat {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    padding: var(--space-8) var(--space-4);
  }

  .pg-cat__inner {
    max-width: 560px;
    text-align: left;
  }

  .pg-cat__eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-2);
  }

  .pg-cat__title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-fg);
    margin: 0 0 var(--space-5);
    line-height: 1.25;
  }

  .pg-cat__body p {
    color: var(--color-fg);
    line-height: 1.65;
    margin: 0 0 var(--space-3);
  }

  .pg-cat__body p + p {
    color: var(--color-fg-muted);
  }

  .pg-cat__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin: var(--space-6) 0 var(--space-5);
  }

  .pg-cat__meta {
    font-size: 0.85rem;
    color: var(--color-fg-muted);
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .pg-cat__meta a {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.6em 1.4em;
    background: var(--color-accent-primary);
    color: var(--color-surface);
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 3px;
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .btn-primary:hover { opacity: 0.85; }

  .btn-ghost {
    display: inline-block;
    padding: 0.6em 1.4em;
    border: 1.5px solid var(--color-border);
    color: var(--color-fg);
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 3px;
    text-decoration: none;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .btn-ghost:hover {
    border-color: var(--color-accent-primary);
    color: var(--color-accent-primary);
  }
</style>
