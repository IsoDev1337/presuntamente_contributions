  .aviso--mostaza {
    background: var(--color-accent-secondary-soft);
    border-left: 3px solid var(--color-accent-secondary-border);
    color: #6b4d00;
  }

  .meta-list { margin: 0; padding-left: 18px; }
  .meta-list li { margin: 4px 0; }
  .meta-list .mono { font-family: var(--font-mono); font-size: 12px; }

  /* === 2.1 Flip 3D de la masthead — la cabecera entera (masthead +
     síntesis del caso) se voltea como una página al pulsar la esquina
     superior derecha, revelando el reverso editorial (estado global +
     10 chequeos + cómo se ha redactado). Perspective 3D real, no
     crossfade. La altura del wrapper se mide con JS porque las dos
     caras tienen contenido distinto. === */
  .ficha-flip {
    position: relative;
    margin-bottom: 24px;
    perspective: 2200px;
    perspective-origin: 50% 30%;
  }
  .ficha-flip__inner {
    position: relative;
    transform-style: preserve-3d;
    transition:
      transform 0.75s cubic-bezier(0.32, 0.04, 0.18, 1),
      min-height 0.45s cubic-bezier(0.2, 0.7, 0.2, 1);
    /* min-height la setea el JS al alto de la cara visible (no al máximo
       de ambas), para que no quede hueco bajo la cara A cuando es más
       corta que la B. La transición es algo más rápida que el flip
       para que la altura cuadre antes de terminar la rotación. */
  }
  .ficha-flip[data-flipped='true'] .ficha-flip__inner {
    transform: rotateY(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .ficha-flip__inner { transition: none; }
  }

  .ficha-flip__face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    /* La clase `.ficha-mast` hereda una animación global `fade-up` que
       define un `transform` en sus keyframes — con `animation-fill-mode:
       both` mantiene el valor final y machaca nuestro `rotateY(180deg)`
       del reverso. Desactivamos la animación dentro del flip. */
    animation: none;
  }
  .ficha-flip__face--front {
    position: relative;
    /* La cara A ocupa el flujo normal y define el tamaño del wrapper en
       SSR/primer paint, antes de que el JS mida y unifique alturas. */
  }
  .ficha-flip__face--back {
    position: absolute;
    inset: 0;
    transform: rotateY(180deg);
  }

  /* --- Botón "esquina doblada" (page corner fold) --------------------- */
  .ficha-flip__corner {
    position: absolute;
    top: 0;
    right: 0;
    width: 56px;
    height: 56px;
    padding: 0;
    margin: 0;
    border: 0;
    background: 0;
    cursor: pointer;
    z-index: 5;
    /* La esquina ocupa el triángulo superior derecho del masthead */
    clip-path: polygon(100% 0, 100% 100%, 0 0);
    transition: width 0.25s cubic-bezier(0.2, 0.7, 0.2, 1),
                height 0.25s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .ficha-flip__corner::before {
    /* "Cara visible" del pliegue: mostaza claro que asoma del reverso */
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      225deg,
      var(--color-accent-secondary) 0%,
      var(--color-accent-secondary-soft) 60%,
      var(--color-accent-secondary-soft) 100%
    );
    clip-path: polygon(100% 0, 100% 100%, 0 0);
    transition: filter 0.2s ease;
  }
  .ficha-flip__corner::after {
    /* Sombra del doblez para dar profundidad: línea diagonal sutil */
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      225deg,
      rgba(0, 0, 0, 0.22) 0%,
      rgba(0, 0, 0, 0.05) 30%,
      transparent 55%
    );
    clip-path: polygon(100% 0, 100% 100%, 0 0);
    pointer-events: none;
  }
  .ficha-flip__corner:hover,
  .ficha-flip__corner:focus-visible {
    width: 72px;
    height: 72px;
    outline: none;
  }
  .ficha-flip__corner:hover::before,
  .ficha-flip__corner:focus-visible::before {
    filter: brightness(1.05);
  }
  .ficha-flip__corner-hint {
    /* Etiqueta accesible y tooltip visual al hover sobre la esquina */
    position: absolute;
    top: 8px;
    right: 8px;
    font: 700 9px/1 var(--font-sans);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #6b4d00;
    opacity: 0;
    transform: rotate(45deg) translate(2px, -8px);
    transform-origin: top right;
    transition: opacity 0.2s ease;
    pointer-events: none;
    white-space: nowrap;
  }
  .ficha-flip__corner:hover .ficha-flip__corner-hint,
  .ficha-flip__corner:focus-visible .ficha-flip__corner-hint {
    opacity: 1;
  }
  /* Cuando la cara B está visible, la esquina vive en la "otra hoja". El
     JS la transplanta visualmente con transformación rotación 180 — pero
     CSS por sí solo no la mueve. En su lugar mantenemos el botón siempre
     visible: al estar la masthead rotada, el botón sigue en la esquina
     superior derecha de lo que ves. */
  .ficha-flip[data-flipped='true'] .ficha-flip__corner::before {
    background: linear-gradient(
      225deg,
      var(--color-accent) 0%,
      var(--color-accent-soft) 60%,
      var(--color-accent-soft) 100%
    );
  }
  .ficha-flip[data-flipped='true'] .ficha-flip__corner-hint {
    color: var(--color-accent);
  }

  /* --- Tipografía y bloques de la cara B ------------------------------- */
  .ficha-flip__title {
    font: 800 26px/1.15 var(--font-display, var(--font-sans));
    letter-spacing: -0.01em;
    margin: 6px 0 10px;
    color: var(--color-fg);
  }
  .ficha-flip__intro {
    margin: 0 0 18px;
    color: var(--color-fg-muted, var(--color-fg));
    font-size: 0.92rem;
    line-height: 1.55;
    max-width: 60ch;
  }
  .ficha-flip__estado-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 18px;
    font-size: 0.92rem;
  }
  .ficha-flip__estado-label {
    color: var(--color-fg-muted, var(--color-fg));
    text-transform: uppercase;
    letter-spacing: var(--ls-caps, 0.04em);
    font-size: 0.74rem;
    font-weight: 700;
  }
  .ficha-flip__chequeos {
    list-style: none;
    margin: 0 0 14px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 8px 24px;
  }
  .ficha-flip__chequeo {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px dashed var(--color-border, #d8dade);
    font-size: 0.92rem;
  }
  .ficha-flip__chequeo-label {
    flex: 1 1 auto;
    color: var(--color-fg);
  }
  .ficha-flip__notas {
    margin: 14px 0 0;
    padding: 10px 12px;
    background: var(--color-surface-muted, var(--color-surface));
    border-left: 3px solid var(--color-border, #cfd1d4);
    font-size: 0.9rem;
    color: var(--color-fg-muted, var(--color-fg));
  }
  .ficha-flip__meta-fecha {
    margin: 10px 0 0;
    color: var(--color-fg-muted, var(--color-fg));
    font-size: 0.84rem;
  }

  @media (max-width: 720px) {
    .ficha-flip__corner {
      width: 44px;
      height: 44px;
    }
    .ficha-flip__corner:hover,
    .ficha-flip__corner:focus-visible {
      width: 56px;
      height: 56px;
    }
    .ficha-flip__chequeo {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }
    .ficha-flip__title {
      font-size: 22px;
    }
  }
</style>

<script>
  // Flip 3D de la masthead. La esquina superior derecha actúa como botón
  // ("page corner fold"). Vanilla, una instancia por PgCasoDetalle.
  //
  // Altura del wrapper: como ambas caras ocupan el mismo espacio
  // (cara B `position: absolute`), el `.ficha-flip__inner` necesita un
  // `min-height` igual al máximo de las dos caras para que la cara más
  // larga no quede recortada al voltear. Lo medimos al cargar y lo
  // re-medimos con ResizeObserver si cambian de tamaño (resize,
  // tipografía dinámica, contenido editado).
  (() => {
    const flip = document.querySelector('.ficha-flip');
    if (!(flip instanceof HTMLElement)) return;
    const inner = flip.querySelector('.ficha-flip__inner');
    const corner = flip.querySelector('.ficha-flip__corner');
    const front = flip.querySelector('.ficha-flip__face--front');
    const back = flip.querySelector('.ficha-flip__face--back');
    if (
      !(inner instanceof HTMLElement) ||
      !(corner instanceof HTMLButtonElement) ||
      !(front instanceof HTMLElement) ||
      !(back instanceof HTMLElement)
    ) {
      return;
    }

    // Aplica el min-height al alto de la cara visible. scrollHeight
    // ignora el rotateY del back y devuelve la altura natural; pero
    // como back tiene position:absolute, su layout no afecta al flujo
    // del inner — necesitamos forzar la altura manualmente.
    const setHeight = () => {
      const flipped = flip.dataset.flipped === 'true';
      const target = flipped ? back : front;
      inner.style.minHeight = `${target.scrollHeight}px`;
    };
    setHeight();

    const apply = (flipped: boolean) => {
      flip.dataset.flipped = flipped ? 'true' : 'false';
      corner.setAttribute('aria-pressed', flipped ? 'true' : 'false');
      front.setAttribute('aria-hidden', flipped ? 'true' : 'false');
      back.setAttribute('aria-hidden', flipped ? 'false' : 'true');
      corner.setAttribute(
        'aria-label',
        flipped ? 'Volver a la ficha' : 'Sobre esta ficha — pasar al reverso',
      );
      const hint = corner.querySelector('.ficha-flip__corner-hint');
      if (hint) hint.textContent = flipped ? 'Volver' : 'Sobre la ficha';
      setHeight();
    };

    corner.addEventListener('click', () => {
      apply(flip.dataset.flipped !== 'true');
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && flip.dataset.flipped === 'true') {
        apply(false);
        corner.focus();
      }
    });

    if ('ResizeObserver' in window) {
      const ro = new ResizeObserver(setHeight);
      ro.observe(front);
      ro.observe(back);
    } else {
      window.addEventListener('resize', setHeight);
    }
  })();
</script>
