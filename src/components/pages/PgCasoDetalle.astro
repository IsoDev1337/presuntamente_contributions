  /* Timeline contenedora. El rail vertical es un ::before absoluto que
     atraviesa el ancho de la columna de rail (32px en desktop, 24px en
     mobile), centrado a 16px / 12px desde el borde izquierdo. Cada Hito
     pinta su dot encima del rail. */
  .timeline {
    position: relative;
    padding: 0 0 0 0;
    display: flex;
    flex-direction: column;
  }
  .timeline.is-reversed { flex-direction: column-reverse; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 16px;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: var(--color-border);
    border-radius: 1px;
  }
  @media (max-width: 560px) {
