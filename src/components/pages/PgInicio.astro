---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PhaseBadge from '@/components/PhaseBadge.astro';
import { getCollection } from 'astro:content';

interface Props {
  lang?: 'es' | 'ca';
}

const { lang = 'es' } = Astro.props;

// --- Cifras del inventario --------------------------------------------------

const [casos, personas, organizaciones, documentos, hitosCol, rolesCol] = await Promise.all([
  getCollection('casos'),
  getCollection('personas'),
  getCollection('organizaciones'),
  getCollection('documentos'),
  getCollection('hitos'),
  getCollection('roles'),
]);

// --- Caso destacado: el más activo (último hito más reciente) --------------
// Ranking simple: para cada caso, fecha del hito más reciente; gana el que
// tiene actividad procesal más reciente. Empate → desempata por
// nivel_relevancia_editorial (capital > alta > media > baja). Cuando haya
// muchos casos convendrá un score más rico (densidad de hitos, fase,
// implicados activos), pero el principio se mantiene: destacar lo VIVO.
const RELEVANCIA_RANK: Record<string, number> = {
  capital: 4,
  alta: 3,
  media: 2,
  baja: 1,
};
const casoDestacado = casos
  .map((c) => {
    const hitos = hitosCol
      .filter((h) => h.data.caso_id === c.data.id)
      .sort((a, b) => b.data.fecha.localeCompare(a.data.fecha));
    return {
      c,
      ultimoHitoFecha: hitos[0]?.data.fecha ?? '0000-00-00',
      relevancia: RELEVANCIA_RANK[c.data.nivel_relevancia_editorial ?? 'media'] ?? 2,
    };
  })
  .sort((a, b) => {
    if (a.ultimoHitoFecha !== b.ultimoHitoFecha) return b.ultimoHitoFecha.localeCompare(a.ultimoHitoFecha);
    return b.relevancia - a.relevancia;
  })[0]?.c.data;

const hitosDestacado = casoDestacado
  ? hitosCol
      .filter((h) => h.data.caso_id === casoDestacado.id)
      .sort((a, b) => b.data.fecha.localeCompare(a.data.fecha))
  : [];
const ultimoHito = hitosDestacado[0]?.data;
const rolesImputadosDestacado = casoDestacado
  ? rolesCol.filter(
      (r) =>
        r.data.caso_id === casoDestacado.id &&
        r.data.sujeto_tipo === 'persona' &&
        ['investigado', 'procesado', 'acusado', 'condenado'].includes(r.data.rol) &&
        !r.data.fecha_fin,
    ).length
  : 0;

// TODO i18n: rama 'ca' cuando se active el catalán.
const strings = {
  title: 'Inicio',
  description:
    'Inventario público, interactivo y open-source de los casos de corrupción más relevantes en España.',
  eyebrow: 'Inventario público · v0.0.0-alpha',
  hero: {
    kicker: 'sin ruido, sin ideología, sin financiación',
    title: 'La corrupción en España, ordenada y con sus fuentes.',
    lede:
      'Un mapa público de los casos judiciales relevantes. Cada hecho cita el documento que lo respalda y su nivel de fuente. Imputación nunca equivale a condena.',
    ctaPrimary: { label: 'Explorar casos', href: '/casos' },
    ctaGhost: { label: 'Cómo se redacta', href: '/sobre' },
  },
  reglas: [
    { num: '01', title: 'Cita siempre', body: 'Cada afirmación con su documento de fuente y nivel N1–N4 visible.' },
    { num: '02', title: 'Sin cuota política', body: 'Casos de cualquier partido, ordenados por relevancia objetiva.' },
    { num: '03', title: 'Presunción de inocencia', body: 'Investigado, procesado y condenado son cosas distintas — y se distinguen.' },
  ],
  contadores: [
    { label: 'Casos catalogados',      value: casos.length },
    { label: 'Personas con rol',       value: personas.length },
    { label: 'Organizaciones citadas', value: organizaciones.length },
    { label: 'Documentos primarios',   value: documentos.length },
  ],
  secciones: [
    {
      key: 'casos',
      num: '01',
      title: 'Catálogo de casos',
      desc: 'Listado tabular con fase, órgano y último hito visibles.',
      href: '/casos',
      cta: 'Ver catálogo',
    },
    {
      key: 'personas',
      num: '02',
      title: 'Personas implicadas',
      desc: 'Índice con trayectoria procesal completa. Sin exposición de privados no implicados.',
      href: '/personas',
      cta: 'Ver personas',
    },
    {
      key: 'organizaciones',
      num: '03',
      title: 'Organizaciones citadas',
      desc: 'Órganos judiciales, fiscalías, partidos, empresas y organismos públicos referenciados.',
      href: '/organizaciones',
      cta: 'Ver organizaciones',
    },
    {
      key: 'biblioteca',
      num: '04',
      title: 'Biblioteca documental',
      desc: 'Sentencias, autos, informes UDEF/UCO, notas institucionales y coberturas cruzadas.',
      href: '/biblioteca',
      cta: 'Ver documentos',
    },
  ],
  disclaimer:
    'Las personas mencionadas como investigadas o procesadas se presumen inocentes hasta que recaiga sentencia firme.',
};
---

<BaseLayout
  title={strings.title}
  lang={lang}
  description={strings.description}
  hideSubstrip={true}
>
  <!-- HERO institucional moderno -->
  <section class="hero">
    <div class="hero__col-text">
      <p class="hero__kicker">{strings.hero.kicker}</p>
      <h1 class="hero__title">{strings.hero.title}</h1>
      <p class="hero__lede">{strings.hero.lede}</p>
      <div class="hero__ctas">
        <a class="cta cta--primary" href={strings.hero.ctaPrimary.href}>
          <span>{strings.hero.ctaPrimary.label}</span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="cta cta--ghost" href={strings.hero.ctaGhost.href}>
          {strings.hero.ctaGhost.label} →
        </a>
      </div>
    </div>
    <aside class="hero__col-aside" aria-label="Cifras del inventario">
      <div class="hero__stamp">
        <span class="hero__stamp-eye">{strings.eyebrow}</span>
        <span class="hero__stamp-date">desde 2026</span>
      </div>
      <ul class="hero__cifras">
        {strings.contadores.map((c) => (
          <li>
            <span class="hero__cifra-val">{c.value}</span>
            <span class="hero__cifra-lbl">{c.label}</span>
          </li>
        ))}
      </ul>
      <a class="hero__cifras-more" href="/cifras">
        Ver todas las cifras →
      </a>
    </aside>
  </section>

  <!-- Tres reglas del proyecto, formato horizontal compacto -->
  <ol class="reglas" aria-label="Principios del inventario">
    {strings.reglas.map((r) => (
      <li class="regla">
        <span class="regla__num">{r.num}</span>
        <h3 class="regla__title">{r.title}</h3>
        <p class="regla__body">{r.body}</p>
      </li>
    ))}
  </ol>

  <!-- CASO DESTACADO: prueba social concreta de cómo es una ficha -->
  {casoDestacado && (
    <section class="destacado">
      <header class="destacado__head">
        <span class="destacado__eye">Caso destacado</span>
        <a class="destacado__more" href={`/casos/${casoDestacado.id}`}>Ver ficha completa →</a>
      </header>
      <a class="destacado__card" href={`/casos/${casoDestacado.id}`}>
        <div class="destacado__main">
          <h2 class="destacado__name">{casoDestacado.nombre_mediatico}</h2>
          <p class="destacado__oficial">{casoDestacado.nombre_oficial}</p>
          {casoDestacado.descripcion_corta && (
            <p class="destacado__desc">{casoDestacado.descripcion_corta}</p>
          )}
        </div>
        <dl class="destacado__meta">
          <div>
            <dt>Fase actual</dt>
            <dd><PhaseBadge fase={casoDestacado.fase_actual} /></dd>
          </div>
          <div>
            <dt>Implicados activos</dt>
            <dd class="destacado__metric">{rolesImputadosDestacado}</dd>
          </div>
          <div>
            <dt>Hitos registrados</dt>
            <dd class="destacado__metric">{hitosDestacado.length}</dd>
          </div>
          {ultimoHito && (
            <div class="destacado__last">
              <dt>Último hito</dt>
              <dd>
                <span class="destacado__mono">{ultimoHito.fecha}</span>
                <span> · {ultimoHito.titulo}</span>
              </dd>
            </div>
          )}
        </dl>
      </a>
    </section>
  )}

  <!-- Secciones del sitio en formato más respirado -->
  <section class="secciones">
    <header class="secciones__head">
      <h2>Explora el inventario</h2>
      <p>Cuatro entradas según lo que busques.</p>
    </header>
    <ul class="secciones__list">
      {strings.secciones.map((s) => (
        <li>
          <a class="seccion" href={s.href}>
            <span class="seccion__num">{s.num}</span>
            <div class="seccion__body">
              <h3 class="seccion__title">{s.title}</h3>
              <p class="seccion__desc">{s.desc}</p>
              <span class="seccion__cta">{s.cta} →</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Pie suave con disclaimer -->
  <p class="bottom-note">{strings.disclaimer}</p>
</BaseLayout>

<style>
  /* ========== HERO ========== */
  .hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-6);
    align-items: center;
    padding: clamp(var(--space-5), 6vw, var(--space-7)) 0 var(--space-6);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-6);
  }
  .hero__kicker {
    font: 700 11px/1 var(--font-sans);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-secondary-hover);
    margin: 0 0 var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero__kicker::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-accent-secondary-hover);
  }
  .hero__title {
    font-family: var(--font-serif), Georgia, serif;
    font-weight: 700;
    font-size: clamp(2rem, 1.4rem + 2.6vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    margin: 0 0 var(--space-4);
    text-wrap: balance;
  }
  .hero__lede {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.18rem);
    line-height: 1.55;
    color: var(--color-fg-muted);
    margin: 0 0 var(--space-5);
    max-width: 55ch;
  }
  .hero__ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font: 600 14px/1 var(--font-sans);
    letter-spacing: 0.01em;
    border: 1px solid;
    border-radius: 0;
    cursor: pointer;
    text-decoration: none;
    transition: transform 140ms ease-out, background 140ms ease-out, color 140ms ease-out;
  }
  .cta svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 180ms ease-out;
  }
  .cta--primary {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .cta--primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }
  .cta--primary:hover svg { transform: translateX(3px); }
  .cta--ghost {
    background: transparent;
    color: var(--color-accent);
    border-color: transparent;
    padding: 12px 8px;
    text-decoration: none;
  }
  .cta--ghost:hover {
    color: var(--color-accent-hover);
    background: var(--color-accent-soft);
  }

  /* Aside derecha del hero: "sello" institucional con cifras */
  .hero__col-aside {
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    position: relative;
  }
  .hero__col-aside::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(
      to right,
      var(--color-accent) 0 50%,
      var(--color-accent-secondary) 50% 100%
    );
  }
  .hero__stamp {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 14px;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .hero__cifras {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .hero__cifras li {
    padding: 14px 16px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero__cifras li:nth-child(2n) { border-right: 0; }
  .hero__cifras li:nth-last-child(-n+2) { border-bottom: 0; }
  .hero__cifras-more {
    display: block;
    padding: 10px 14px;
    border-top: 1px solid var(--color-border);
    font: 600 12px/1 var(--font-sans);
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    background: var(--color-surface);
    text-align: right;
    transition: background 140ms ease-out, color 140ms ease-out;
  }
  .hero__cifras-more:hover {
    background: var(--color-bg-muted);
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .hero__cifra-val {
    font: 700 clamp(1.6rem, 1.2rem + 1vw, 2.2rem)/1 var(--font-sans);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }
  .hero__cifra-lbl {
    font: 600 10px/1.3 var(--font-sans);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
  }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; gap: var(--space-5); }
  }

  /* ========== 3 reglas en horizontal ========== */
  .reglas {
    list-style: none;
    margin: 0 0 var(--space-7);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .regla {
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-top: 3px solid var(--color-accent-secondary-border);
    transition: border-top-color 200ms ease-out, transform 200ms ease-out;
  }
  .regla:hover {
    border-top-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .regla__num {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }
  .regla__title {
    font: 700 var(--font-size-3)/1.2 var(--font-sans);
    margin: 6px 0 4px;
    color: var(--color-fg);
  }
  .regla__body {
    font: 400 13px/1.55 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0;
  }
  @media (max-width: 720px) {
    .reglas { grid-template-columns: 1fr; }
  }

  /* ========== CASO DESTACADO ========== */
  .destacado { margin-bottom: var(--space-7); }
  .destacado__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 8px;
  }
  .destacado__eye {
    font: 700 11px/1 var(--font-sans);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-secondary-hover);
  }
  .destacado__more {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }
  .destacado__more:hover { text-decoration: underline; text-underline-offset: 3px; }
  .destacado__card {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 0;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-left-width 180ms ease-out, background 180ms ease-out, transform 180ms ease-out;
  }
  .destacado__card:hover {
    border-left-width: 6px;
    background: var(--color-bg-muted);
  }
  .destacado__main {
    padding: var(--space-5) var(--space-5);
    border-right: 1px solid var(--color-border);
  }
  .destacado__name {
    font-family: var(--font-serif), Georgia, serif;
    font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 6px;
    color: var(--color-fg);
  }
  .destacado__oficial {
    font: 400 13px/1.4 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0 0 var(--space-3);
  }
  .destacado__desc {
    font: 400 14px/1.6 var(--font-sans);
    color: var(--color-fg);
    margin: 0;
  }
  .destacado__meta {
    margin: 0;
    padding: var(--space-3);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-content: start;
  }
  .destacado__meta > div {
    padding: 10px 12px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .destacado__meta > div:nth-child(2n) { border-right: 0; }
  .destacado__meta dt {
    font: 600 10px/1 var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-fg-muted);
  }
  .destacado__meta dd {
    margin: 0;
    font: 400 13px/1.4 var(--font-sans);
  }
  .destacado__metric {
    font: 700 clamp(1.4rem, 1.2rem + 0.5vw, 1.8rem)/1 var(--font-sans);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }
  .destacado__last {
    grid-column: 1 / -1;
    border-right: 0 !important;
    border-bottom: 0 !important;
  }
  .destacado__mono { font-family: var(--font-mono); font-size: 12px; }

  @media (max-width: 720px) {
    .destacado__card { grid-template-columns: 1fr; }
    .destacado__main { border-right: 0; border-bottom: 1px solid var(--color-border); }
  }

  /* ========== Secciones del sitio (formato amable) ========== */
  .secciones { margin-bottom: var(--space-7); }
  .secciones__head {
    margin-bottom: var(--space-4);
    text-align: center;
  }
  .secciones__head h2 {
    font-family: var(--font-serif), Georgia, serif;
    font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .secciones__head p {
    font: 400 14px/1.5 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0;
  }
  .secciones__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .seccion {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 180ms ease-out, transform 180ms ease-out, background 180ms ease-out;
  }
  .seccion:hover {
    border-color: var(--color-accent);
    background: var(--color-bg-muted);
    transform: translateY(-2px);
  }
  .seccion__num {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: var(--font-size-3);
    color: var(--color-accent-secondary-hover);
    line-height: 1;
  }
  .seccion__title {
    font: 700 var(--font-size-3)/1.2 var(--font-sans);
    margin: 0 0 6px;
    color: var(--color-fg);
  }
  .seccion__desc {
    font: 400 13px/1.55 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0 0 var(--space-3);
  }
  .seccion__cta {
    font: 600 13px/1 var(--font-sans);
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .seccion:hover .seccion__cta { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 720px) {
    .secciones__list { grid-template-columns: 1fr; }
  }

  /* ========== Disclaimer ========== */
  .bottom-note {
    text-align: center;
    font: 400 12px/1.5 var(--font-sans);
    color: var(--color-fg-subtle);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin: 0 auto;
    max-width: 56ch;
  }
</style>
