---
// RolBadge — badge único para cualquier rol de RolEnCaso.
//
// La elección de familia visual es responsabilidad de este componente, no del
// caller. Caller pasa `rol` (slug del enum) y opcionalmente `label`; el badge
// decide:
//   - F-estado (rol del lado acusado): dot + fondo suave, sin borde (como
//     EstadoFichaBadge). Cubre
//     investigado, procesado, acusado, condenado_no_firme, condenado_firme,
//     absuelto, desimputado, testigo.
//   - F-función aparato judicial: border-left navy + fondo neutro + label.
//     Cubre juez_*, fiscal, magistrado, abogado_*, perito_*, secretario_judicial.
//   - F-función acusación civil + parte civil: border-left azul-suave + fondo
//     neutro + label. Cubre denunciante, querellante, acusacion_*, perjudicado.
//
// La regla CSS de cada `.badge--rol-${rol}` ya está en global.css. La familia
// "estado" añade el modificador `badge--estado-soft` y el dot; el resto se
// distingue por color del border-left + label.

import { rolLabel, rolFamilia, type Lang } from '@/lib/labels';

interface Props {
  rol: string;
  label?: string;
  ghost?: boolean;
  lang?: Lang;
}
const { rol, label, ghost = false, lang = 'es' } = Astro.props;
const text = label ?? rolLabel(rol, lang);
const familia = rolFamilia(rol);
---
<span class:list={['badge', `badge--rol-${rol}`, familia === 'estado' && 'badge--estado-soft', ghost && 'badge--ghost']}>
  {familia === 'estado' && (
    <span class="dot" aria-hidden="true"></span>
  )}
  {text}
</span>
