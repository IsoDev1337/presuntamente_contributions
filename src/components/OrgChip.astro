---
/**
 * Chip genérico de organización para listados densos.
 * Mantiene el estilo de OrgAfectadaChip, sin semántica de afectación.
 */
import PartidoBadge from '@/components/PartidoBadge.astro';

interface Props {
  id: string;
  label: string;
  href?: string;
  esPartido?: boolean;
  size?: 'sm' | 'md';
}

const { id, label, href, esPartido = false, size = 'sm' } = Astro.props;
---

<span class:list={['org-chip', size === 'md' && 'org-chip--md']}>
  {esPartido ? (
    <PartidoBadge id={id} label={label} href={href} size={size} />
  ) : href ? (
    <a class="org-chip__link" href={href}>{label}</a>
  ) : (
    <span class="org-chip__link org-chip__link--static">{label}</span>
  )}
</span>

<style>
  .org-chip {
    display: inline-flex;
    max-width: var(--org-chip-max, 12rem);
    min-width: 0;
    vertical-align: middle;
  }
  .org-chip :global(a.partido-badge),
  .org-chip :global(span.partido-badge) {
    display: block;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .org-chip__link {
    display: block;
    max-width: 100%;
    overflow: hidden;
    padding: 1px 7px;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    background: var(--color-surface-muted, var(--color-surface));
    color: var(--color-fg);
    font: 500 11px/1.45 var(--font-sans);
    text-decoration: none;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .org-chip--md .org-chip__link {
    padding: 2px 8px;
    font-size: 12px;
  }
  a.org-chip__link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }
  .org-chip__link--static {
    color: var(--color-fg-muted);
  }
</style>
