---
// EstadoFichaBadge — badge para el campo `estado_ficha.<check>` del Caso.
// Cuatro estados discretos con color suave + label de texto, sin glyph
// decorativo (ver AGENTS.md → "Convención de referencias y citas",
// punto 4 sobre el sistema de badges).
//
// Estilos scoped en este mismo fichero para no inflar global.css y para
// respetar la coordinación multiagéntica de esta sesión (global.css está
// en manos del worktree bloque-e).
//
// Mapeo:
//   completo   — verde, alineado con --color-acreditado (epistémico)
//   parcial    — mostaza, alineado con --color-accent-secondary
//   pendiente  — gris navy suave, alineado con --color-rol-investigado
//   no_aplica  — gris desaturado, sin contraste fuerte

interface Props {
  estado: 'completo' | 'parcial' | 'pendiente' | 'no_aplica';
  /** Texto opcional debajo del badge (justificación corta de `parcial`/`pendiente`). */
  detalle?: string;
}

const { estado, detalle } = Astro.props;

const LABELS: Record<Props['estado'], string> = {
  completo: 'Completo',
  parcial: 'Parcial',
  pendiente: 'Pendiente',
  no_aplica: 'No aplica',
};
---

<span class:list={['estado-badge', `estado-badge--${estado.replace('_', '-')}`]}>
  <span class="estado-badge__dot" aria-hidden="true"></span>
  <span class="estado-badge__label">{LABELS[estado]}</span>
  {detalle && <span class="estado-badge__detalle"> — {detalle}</span>}
</span>

<style>
  .estado-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.02em;
    padding: 0.18em 0.6em 0.18em 0.5em;
    border-radius: 2px;
    border: 1px solid;
    background: var(--color-surface);
    white-space: nowrap;
  }

  .estado-badge__dot {
    flex-shrink: 0;
    inline-size: 8px;
    block-size: 8px;
    border-radius: 50%;
    background: currentColor;
  }

  .estado-badge__label {
    text-transform: none;
  }

  .estado-badge__detalle {
    font-weight: 400;
    color: var(--color-fg-muted, var(--color-fg));
    opacity: 0.85;
    white-space: normal;
  }

  /* Estados ---------------------------------------------------------------- */

  .estado-badge--completo {
    color: var(--color-acreditado);
    border-color: var(--color-acreditado-border);
    background: var(--color-acreditado-bg);
  }

  .estado-badge--parcial {
    color: #6b4d00;
    border-color: var(--color-accent-secondary-border);
    background: var(--color-accent-secondary-soft);
  }

  .estado-badge--pendiente {
    color: var(--color-rol-investigado);
    border-color: var(--color-rol-investigado);
    background: var(--color-surface);
  }

  .estado-badge--no-aplica {
    color: var(--color-fg-muted, #6c6f73);
    border-color: var(--color-border, #cfd1d4);
    background: var(--color-surface);
    opacity: 0.78;
  }

  /* Dark mode: el proyecto usa @media (prefers-color-scheme: dark) y
     overridea tokens en :root. Los colores hardcoded de `completo`,
     `parcial` y `pendiente` (escogidos para contrastar sobre fondo claro)
     pierden contraste sobre fondos oscuros, así que aquí los re-pinto
     con foregrounds claros propios del modo oscuro. Los backgrounds
     ya son los `_bg` / `_soft` que el global.css redefine en oscuro. */
  @media (prefers-color-scheme: dark) {
    .estado-badge--completo {
      color: #9ec5a7;
      border-color: var(--color-acreditado-border);
    }
    .estado-badge--parcial {
      color: var(--color-accent-secondary);
      border-color: var(--color-accent-secondary-border);
    }
    .estado-badge--pendiente {
      color: var(--color-accent);
      border-color: var(--color-accent);
    }
    .estado-badge--no-aplica {
      color: var(--color-fg-subtle, var(--color-fg-muted));
      border-color: var(--color-border, #2e3035);
    }
  }
</style>
