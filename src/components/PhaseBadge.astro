---
// PhaseBadge — badge de fase procesal.
// Mapea los 10 valores del enum `fase_actual` a 4 buckets de UI:
// instr / juicio / firme / archivo. Archivo tiene estilo propio
// (--phase-archivo, gris desaturado, peso normal) distinto a firme para
// no confundir "cerrado con sentencia firme" con "archivado sin condena".
interface Props {
  fase: string;
}
const { fase } = Astro.props;

function mapFase(f: string): { kind: 'instr' | 'juicio' | 'firme' | 'archivo'; label: string } {
  if (f === 'instruccion' || f === 'fase_intermedia' || f === 'denuncia_o_querella') {
    return { kind: 'instr', label: 'Instrucción' };
  }
  if (f === 'juicio_oral' || f === 'sentencia_primera_instancia' || f === 'recurso') {
    return { kind: 'juicio', label: 'Juicio oral' };
  }
  if (f === 'sentencia_firme' || f === 'ejecucion') {
    return { kind: 'firme', label: 'Sentencia firme' };
  }
  if (f === 'archivo_provisional') {
    return { kind: 'archivo', label: 'Archivo provisional' };
  }
  if (f === 'archivo_libre') {
    return { kind: 'archivo', label: 'Archivo libre' };
  }
  return { kind: 'instr', label: f };
}

const { kind, label } = mapFase(fase);
---
<span class:list={['badge', `badge--phase-${kind}`]}>{label}</span>
