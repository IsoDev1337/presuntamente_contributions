---
// PhaseBadge — badge de fase procesal del caso (familia F4).
// Mapea los 10 valores del enum `fase_actual` a 5 buckets de UI con
// micro-barra de progreso en la base (DESIGN.md §"Sistema de badges"):
//   instr      → [█░░░]   Instrucción (incl. denuncia/querella inicial)
//   intermedia → [██░░]   Fase intermedia (procesado, escrito acusación)
//   juicio     → [███░]   Juicio oral, sentencia 1ª instancia, recurso
//   firme      → [████]   Sentencia firme, ejecución
//   archivo    → [░░░░]   Archivo provisional o libre (gris desaturado)
interface Props {
  fase: string;
}
const { fase } = Astro.props;

function mapFase(f: string): { kind: 'instr' | 'intermedia' | 'juicio' | 'firme' | 'archivo'; label: string } {
  if (f === 'instruccion' || f === 'denuncia_o_querella') {
    return { kind: 'instr', label: 'Instrucción' };
  }
  if (f === 'fase_intermedia') {
    return { kind: 'intermedia', label: 'Fase intermedia' };
  }
  if (f === 'juicio_oral' || f === 'sentencia_primera_instancia' || f === 'recurso') {
    return { kind: 'juicio', label: 'Juicio oral' };
  }
  if (f === 'sentencia_firme' || f === 'ejecucion') {
    return { kind: 'firme', label: 'Sentencia firme' };
  }
  if (f === 'archivo_provisional') {
    return { kind: 'archivo', label: 'Archivo provisional' };
  }
  if (f === 'archivo_libre') {
    return { kind: 'archivo', label: 'Archivo libre' };
  }
  return { kind: 'instr', label: f };
}

const { kind, label } = mapFase(fase);
---
<span class:list={['badge', `badge--phase-${kind}`]}>{label}</span>
