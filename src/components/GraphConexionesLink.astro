---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a class="btn btn--primary" href={href}>
  <svg class="btn__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <circle cx="5" cy="19" r="2.25" fill="none" stroke="currentColor" stroke-width="1.75" />
    <circle cx="19" cy="5" r="2.25" fill="none" stroke="currentColor" stroke-width="1.75" />
    <circle cx="19" cy="19" r="2.25" fill="none" stroke="currentColor" stroke-width="1.75" />
    <path
      d="M7.2 17.2 16.8 7.2 M7.2 17.2 16.8 17.2"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
    />
  </svg>
  <span>Ver en grafo de conexiones</span>
</a>
