---
// Hito — fila de la timeline cronológica de la ficha de caso.
// Markup canónico en preview/comp_hito.html. Estructura:
//   [date-cell con CalGlyph]  [hito: badge tipo + ind hechos · título · desc]
//
// El badge de familia (jurisdiccional / político / mediático) usa la
// familia F5 del sistema de badges (DESIGN.md §"Sistema de badges"):
// fondo neutro + glyph monocromo. No comparte paleta con la fase (F4)
// para evitar la colisión visual previa.

import CalGlyph from './CalGlyph.astro';
import RichProse from './RichProse.astro';

interface Props {
  fecha: string;
  precision: 'dia' | 'mes' | 'anio';
  tipo: string;
  tipoLabel: string;
  tipoFamilia: 'jurisdiccional' | 'politico' | 'mediatico';
  titulo: string;
  descripcion?: string;
  documentoTitulo?: string;
  documentoHref?: string;
  documentoNivel?: 1 | 2 | 3 | 4;
}

const {
  fecha,
  precision,
  tipoLabel,
  tipoFamilia,
  titulo,
  descripcion,
  documentoTitulo,
  documentoHref,
  documentoNivel,
} = Astro.props;

// Glyph rendering por subfamilia:
//   - jurisdiccional → SVG balanza inline (mismo que aparato judicial)
//   - politico       → ◆ U+25C6 (diamond) — bien cubierto en fuentes humanistas
//   - mediatico      → ¶ U+00B6 (pilcrow) — idem
const FAMILIA_GLYPH_CHAR: Record<Exclude<Props['tipoFamilia'], 'jurisdiccional'>, string> = {
  politico:  '◆',
  mediatico: '¶',
};
---
<div class="hito-item">
  <div class="hito-item__date">
    <CalGlyph fecha={fecha} precision={precision} />
  </div>
  <div class="hito-item__body">
    <div class="hito-item__head">
      <span class:list={['badge', 'badge--cat', `badge--cat-${tipoFamilia}`]}>
        {tipoFamilia === 'jurisdiccional' ? (
          <svg class="glyph-svg" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <line x1="8" y1="2" x2="8" y2="14"/>
            <line x1="3" y1="14" x2="13" y2="14"/>
            <line x1="3" y1="4" x2="13" y2="4"/>
            <path d="M3 4 L1 9 A2.2 2.2 0 0 0 5 9 Z"/>
            <path d="M13 4 L11 9 A2.2 2.2 0 0 0 15 9 Z"/>
          </svg>
        ) : (
          <span class="glyph" aria-hidden="true">{FAMILIA_GLYPH_CHAR[tipoFamilia]}</span>
        )}
        {tipoLabel}
      </span>
      {documentoTitulo && documentoNivel && (
        <span class="hito-item__doc">
          <span class:list={['badge', `badge--n${documentoNivel}`]}>N{documentoNivel}</span>
          {documentoHref ? (
            <a href={documentoHref}>{documentoTitulo}</a>
          ) : (
            <span>{documentoTitulo}</span>
          )}
        </span>
      )}
    </div>
    <h4 class="hito-item__title">{titulo}</h4>
    {descripcion && <RichProse text={descripcion} class="hito-item__desc" />}
  </div>
</div>

<style>
  .hito-item {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 0;
    border-bottom: 1px solid var(--color-border);
    align-items: stretch;
    transition: background 160ms ease-out;
  }
  .hito-item:last-child { border-bottom: 0; }
  .hito-item:hover { background: var(--color-bg-muted); }
  .hito-item__date {
    background: var(--color-surface-muted);
    border-right: 1px solid var(--color-border);
    padding: 14px 12px;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .hito-item__body { padding: 14px 16px; }
  .hito-item__head {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .hito-item__title {
    font: 700 14px/1.3 var(--font-sans);
    margin: 4px 0;
  }
  .hito-item__desc {
    font: 400 13px/1.55 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0;
  }
  .hito-item__doc {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-muted);
  }
  .hito-item__doc a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
