---
// Hito — fila de la timeline cronológica de la ficha de caso.
// Layout: [rail+dot] [CalGlyph] [body].
// El rail es una línea vertical 2px que conecta todos los dots de la
// cronología; cada dot se colorea por `tipoFamilia` (navy jurisdiccional /
// mostaza político / gris mediático). El badge de categoría usa color +
// label de texto, sin glyph decorativo.
// El rail visual lo pinta el contenedor `.timeline` en PgCasoDetalle.astro
// como `::before` absoluto; aquí cada item solo dibuja su dot.

import AnchorLink from './AnchorLink.astro';
import CalGlyph from './CalGlyph.astro';
import CategoryBadge from './CategoryBadge.astro';
import RichProse from './RichProse.astro';

interface Props {
  /** Slug del Hito. Si se pasa, se renderiza como id del bloque para
   *  deep-linking estable (feed RSS/Atom, citas externas). */
  id?: string;
  fecha: string;
  precision: 'dia' | 'mes' | 'anio';
  tipo: string;
  tipoLabel: string;
  tipoFamilia: 'jurisdiccional' | 'politico' | 'mediatico';
  titulo: string;
  descripcion?: string;
  documentoTitulo?: string;
  documentoHref?: string;
  documentoNivel?: 1 | 2 | 3 | 4;
  excludeOrgIds?: string[];
  excludePersonaIds?: string[];
}

const {
  id,
  fecha,
  precision,
  tipoLabel,
  tipoFamilia,
  titulo,
  descripcion,
  documentoTitulo,
  documentoHref,
  documentoNivel,
  excludeOrgIds,
  excludePersonaIds,
} = Astro.props;
---
<div class:list={['hito-item', `hito-item--${tipoFamilia}`]} id={id ? `hito-${id}` : undefined}>
  {id && <AnchorLink target={`hito-${id}`} label={`Copiar enlace a este hito: ${titulo}`} />}
  <div class="hito-item__rail" aria-hidden="true">
    <span class="hito-item__dot"></span>
  </div>
  <div class="hito-item__date">
    <CalGlyph fecha={fecha} precision={precision} />
  </div>
  <div class="hito-item__body">
    <div class="hito-item__head">
      <CategoryBadge
        kind="hito"
        tipo={tipoFamilia}
        familia={tipoFamilia}
        label={tipoLabel}
      />
      {documentoTitulo && documentoNivel && (
        <span class="hito-item__doc">
          <span class:list={['badge', `badge--n${documentoNivel}`]}>N{documentoNivel}</span>
          {documentoHref ? (
            <a href={documentoHref}>{documentoTitulo}</a>
          ) : (
            <span>{documentoTitulo}</span>
          )}
        </span>
      )}
    </div>
    <h4 class="hito-item__title">{titulo}</h4>
    {descripcion && (
      <RichProse
        text={descripcion}
        class="hito-item__desc"
        excludeOrgIds={excludeOrgIds}
        excludePersonaIds={excludePersonaIds}
      />
    )}
  </div>
</div>

<style>
  .hito-item {
    display: grid;
    grid-template-columns: 32px 84px 1fr;
    gap: 0;
    padding: 14px 0 18px;
    align-items: stretch;

    --dot-color: var(--color-border-strong);
  }
  .hito-item--jurisdiccional { --dot-color: var(--color-accent); }
  .hito-item--politico       { --dot-color: var(--color-accent-secondary); }
  .hito-item--mediatico      { --dot-color: var(--color-border-strong); }

  .hito-item:first-child { padding-top: 4px; }
  .hito-item:last-child  { padding-bottom: 4px; }

  /* Rail column: centra el dot a la altura del badge de categoría. */
  .hito-item__rail {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 2px;
  }
  .hito-item__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 3px solid var(--dot-color);
    box-shadow: 0 0 0 3px var(--color-surface);
    /* el box-shadow "tapa" el rail detrás del dot para que la línea
       no se vea cruzarlo */
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .hito-item__date {
    padding: 0 16px 0 12px;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .hito-item__body { padding: 0 4px 0 0; min-width: 0; }
  .hito-item__head {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .hito-item__title {
    font: 700 14px/1.3 var(--font-sans);
    margin: 4px 0;
  }
  .hito-item__desc {
    font: 400 13px/1.55 var(--font-sans);
    color: var(--color-fg-muted);
    margin: 0;
  }
  .hito-item__doc {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-fg-muted);
  }
  .hito-item__doc a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Mobile: la columna del rail se mantiene pero más estrecha. El
     CalGlyph y el body siguen renderizando sin colisión gracias al
     min-width:0 en __body. */
  @media (max-width: 560px) {
    .hito-item {
      grid-template-columns: 24px 64px 1fr;
      padding: 14px 0;
    }
    .hito-item__date { padding: 0 10px 0 8px; }
    .hito-item__dot {
      width: 12px;
      height: 12px;
      border-width: 2.5px;
    }
  }
</style>
